# ── Database ─────────────────────────────────────────────────────────────────
# Render free PostgreSQL — copy the "External Database URL" from your DB dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Get these from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=any_random_secret_you_choose
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI (Anthropic / Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://kenya-bot.onrender.com
NODE_ENV=production
PORT=3000
